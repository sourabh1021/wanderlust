<% layout("/layouts/boilerplate") %>


    <div class="row mt-3">
        <h1 class="col-6 offset-3">SignUp on Wanderlust</h1>
        <div class="col-6 offset-3">
            <form action="/signup" method="post" class="needs-validation" novalidate>


                <div class="mb-3"> <!--mb == margin-bottom-->
                    <label for="title" class="form-label">username: </label>
                    <input type="text" name="username" id="username" class="form-control"
                        required>
                    <div class="valid-feedback"><b>Looks Good</b></div>
                    <div class="invalid-feedback"><b>Please Enter Valid username</b></div>
                </div>
                <div class="mb-3"> <!--mb == margin-bottom-->
                    <label for="title" class="form-label">Email: </label>
                    <input type="email" name="email" id="email" class="form-control"
                    required>
                    <div class="invalid-feedback"><b>Please Enter Valid email Id</b></div>
                </div>
                <div class="mb-3"> <!--mb == margin-bottom-->
                    <label for="title" class="form-label">Password: </label>
                    <input type="password" name="password" id="password" class="form-control"
                    required>
                    <div class="valid-feedback"><b>Looks strong password</b></div>
                    <div class="invalid-feedback"><b>Please Enter Valid password</b></div>
                </div>
                <button class="btn btn-success">SignUp</button>
        </div>
    </div>