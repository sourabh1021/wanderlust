<% layout("/layouts/boilerplate") %>


    <div class="row mt-3">
        <h1 class="col-6 offset-3">login on Wanderlust</h1>
        <div class="col-6 offset-3">
            <form action="/login" method="post" class="needs-validation" novalidate>


                <div class="mb-3"> <!--mb == margin-bottom-->
                    <label for="title" class="form-label">username: </label>
                    <input type="text" name="username" id="username" class="form-control"
                        required>
                    <div class="invalid-feedback"><b>Please Enter correct username</b></div>
                </div>
                
                <div class="mb-3"> <!--mb == margin-bottom-->
                    <label for="title" class="form-label">Password: </label>
                    <input type="password" name="password" id="password" class="form-control"
                    required>
                    <div class="invalid-feedback"><b>Please Enter correct password</b></div>
                </div>
                <button class="btn btn-success">SignUp</button>
        </div>
    </div>