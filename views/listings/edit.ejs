<% layout("/layouts/boilerplate") %>

    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h2>Edit your Listing </h2>
            <form action="/listings/<%= editListing._id %>?_method=PUT" method="POST" novalidate
                class="needs-validation">

                <div class="mb-3">
                    <label for="title" class="form-label">Title: </label>
                    <input type="text" name="listing[title]" value="<%= editListing.title %>" class="form-control"
                        required>
                    <div class="valid-feedback"><b>Title Looks Good</b></div>
                    <div class="invalid-feedback"><b>Please Enter Valid Title</b></div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">discription: </label>
                    <textarea type="text" name="listing[description]" class="form-control"
                        required><%= editListing.description %> </textarea>
                        <div class="valid-feedback"><b>Nice Discription</b></div>
                        <div class="invalid-feedback"><b>Please Enter Valid Discription</b></div>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image/URL: </label>
                    <input type="text" name="listing[image][url]" placeholder="Enter image URL/LINK"
                        value="<%= editListing.image.url %>" class="form-control" required>
                        <div class="valid-feedback"><b>Great</b></div>
                        <div class="invalid-feedback"><b>Please Enter Valid Image/URL</b></div>
                </div>
                <div class="mb-3">
                    <label for="Price" class="form-label">Price: </label>
                    <input type="number" name="listing[price]" value="<%= editListing.price %>" class="form-control"
                        required>
                        <div class="valid-feedback"><b>Good price</b></div>
                        <div class="invalid-feedback"><b>Please Enter Valid Price</b></div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="Location" class="form-label">Location: </label>
                        <input type="text" name="listing[location]" value="<%= editListing.location %>"
                            class="form-control" required>
                            <div class="valid-feedback"><b>Nice Location</b></div>
                        <div class="invalid-feedback"><b>Please Enter Valid Location</b></div>
                    </div>
                    <div class="mb-3 col-md-6">
                        <label for="Country" class="form-label">Country: </label>
                        <input type="text" name="listing[country]" value="<%= editListing.country %>"
                            class="form-control" required>
                            <div class="valid-feedback"><b>I'ts Very Beautiful Country</b></div>
                        <div class="invalid-feedback"><b>Please Enter Valid Country</b></div>
                    </div>
                </div>

                <button type="submit" class="btn btn-dark edit-btn mt-3">Edit</button>

            </form>
        </div>
    </div>